# =============================================================
# QRaksha — Cloud Functions Environment Variables
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values below in your LOCAL .env
#   3. NEVER commit .env — it is in .gitignore
#   4. For production: set these in Firebase Secret Manager
#      (Firebase console → Functions → Secret Manager)
#      OR via:  firebase functions:secrets:set MESH_API_KEY
# =============================================================

# Mesh AI API Key (from mesh.ai — server-side only, never in frontend)
MESH_API_KEY=your_mesh_api_key_here

# NumVerify API Key (from apilayer.com — server-side only)
NUMVERIFY_API_KEY=your_numverify_api_key_here

# Optional: Add your custom domain to the CORS allowlist
# (GitHub Pages and Firebase Hosting URLs are always included)
# CORS_ORIGIN=https://your-custom-domain.com
